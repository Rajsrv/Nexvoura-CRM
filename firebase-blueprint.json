{
  "entities": {
    "Company": {
      "title": "Company",
      "description": "A tenant company in the SaaS platform.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the company." },
        "subdomain": { "type": "string", "description": "The unique subdomain slug for this tenant." },
        "logoUrl": { "type": "string", "description": "The URL of the company logo." },
        "createdAt": { "type": "string", "format": "date-time" },
        "trialEndsAt": { "type": "string", "format": "date-time" },
        "notificationSettings": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "dueSoonHours": { "type": "number", "default": 24 }
          }
        }
      },
      "required": ["name", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "A user belonging to a company with employee details.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "companyId": { "type": "string", "description": "The ID of the company this user belongs to." },
        "role": { "type": "string", "enum": ["admin", "manager", "team_lead", "sales"] },
        "phone": { "type": "string" },
        "department": { "type": "string", "enum": ["Sales", "Dev", "Support"] },
        "joiningDate": { "type": "string", "format": "date" },
        "salary": { "type": "number" },
        "status": { "type": "string", "enum": ["Active", "On Leave", "Left"] },
        "isResigned": { "type": "boolean" },
        "shiftId": { "type": "string" },
        "bankDetails": {
          "type": "object",
          "properties": {
            "accountName": { "type": "string" },
            "accountNumber": { "type": "string" },
            "bankName": { "type": "string" },
            "ifscCode": { "type": "string" },
            "branchName": { "type": "string" }
          }
        },
        "governmentId": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["Aadhar", "PAN", "Passport", "Voter ID"] },
            "number": { "type": "string" }
          }
        },
        "salaryHistory": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "amount": { "type": "number" },
              "date": { "type": "string", "format": "date" },
              "reason": { "type": "string" },
              "previousSalary": { "type": "number" },
              "newSalary": { "type": "number" }
            }
          }
        },
        "emergencyContact": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "phone": { "type": "string" },
            "relation": { "type": "string" }
          }
        },
        "permissions": { "type": "array", "items": { "type": "string" } },
        "interests": { "type": "array", "items": { "type": "string" }, "description": "User specific interests for personalized intelligence." },
        "reportsTo": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "companyId", "role", "createdAt"]
    },
    "IntelligencePost": {
      "title": "IntelligencePost",
      "description": "Internal company updates or curated global intelligence signals.",
      "type": "object",
      "properties": {
        "companyId": { "type": "string", "description": "The company this post is relevant to. For global signals, this might be a generic platform ID or null." },
        "type": { "type": "string", "enum": ["Internal", "Global"] },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "topic": { "type": "string" },
        "source": { "type": "string" },
        "imageUrl": { "type": "string" },
        "link": { "type": "string" },
        "relevance": { "type": "number", "description": "Score from 0-100 indicating importance." },
        "createdAt": { "type": "string", "format": "date-time" },
        "authorId": { "type": "string" }
      },
      "required": ["type", "title", "content", "topic", "createdAt"]
    },
    "PermissionRequest": {
      "title": "PermissionRequest",
      "description": "Requests for additional granular permissions.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "companyId": { "type": "string" },
        "requestedPermission": { "type": "string" },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "resolvedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "resolvedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "companyId", "requestedPermission", "status", "createdAt"]
    },
    "Shift": {
      "title": "Shift",
      "description": "Work shifts and schedules.",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "name": { "type": "string" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "type": { "type": "string", "enum": ["Full-time", "Night", "Remote", "Hybrid"] },
        "workDays": { "type": "array", "items": { "type": "number" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["companyId", "name", "startTime", "endTime", "type", "workDays", "createdAt"]
    },
    "Holiday": {
      "title": "Holiday",
      "description": "Company and public holidays.",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["Public", "Company", "Optional"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["companyId", "date", "name", "type", "createdAt"]
    },
    "EmployeeDocument": {
      "title": "EmployeeDocument",
      "description": "Stored documents for an employee.",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "employeeId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["Offer Letter", "ID Proof", "Contract", "Other"] },
        "fileUrl": { "type": "string" },
        "uploadedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["companyId", "employeeId", "name", "type", "fileUrl", "uploadedAt"]
    },
    "ExitRecord": {
      "title": "ExitRecord",
      "description": "Exit/Resignation management record.",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "employeeId": { "type": "string" },
        "resignationDate": { "type": "string", "format": "date" },
        "lastWorkingDay": { "type": "string", "format": "date" },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Checklist Done", "Settled"] },
        "checklist": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "task": { "type": "string" },
              "completed": { "type": "boolean" }
            }
          }
        },
        "finalSettlementAmount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["companyId", "employeeId", "resignationDate", "lastWorkingDay", "status", "createdAt"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Daily employee attendance.",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "employeeId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "checkIn": { "type": "string", "format": "date-time" },
        "checkOut": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["On-time", "Late", "Absent"] },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "address": { "type": "string" }
          }
        }
      },
      "required": ["companyId", "employeeId", "date", "checkIn", "status"]
    },
    "LeaveRequest": {
      "title": "LeaveRequest",
      "description": "Employee leave requests.",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "employeeId": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "type": { "type": "string", "enum": ["Annual", "Sick", "Work From Home", "Other"] },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["companyId", "employeeId", "startDate", "endDate", "type", "status", "createdAt"]
    },
    "PerformanceReview": {
      "title": "PerformanceReview",
      "description": "Employee performance evaluations.",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "employeeId": { "type": "string" },
        "reviewerId": { "type": "string" },
        "period": { "type": "string" },
        "rating": { "type": "number", "minimum": 1, "maximum": 5 },
        "feedback": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["companyId", "employeeId", "reviewerId", "rating", "createdAt"]
    },
    "Payroll": {
      "title": "Payroll",
      "description": "Monthly payroll records.",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "employeeId": { "type": "string" },
        "employeeName": { "type": "string" },
        "month": { "type": "string" },
        "baseSalary": { "type": "number" },
        "bonus": { "type": "number" },
        "bonusReason": { "type": "string" },
        "deductions": { "type": "number" },
        "deductionReason": { "type": "string" },
        "taxAmount": { "type": "number" },
        "netSalary": { "type": "number" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["Paid", "Pending"] },
        "approvedBy": { "type": "string", "description": "UID of the admin/manager who approved." },
        "approvedAt": { "type": "string", "format": "date-time" },
        "paidAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["companyId", "employeeId", "month", "baseSalary", "totalAmount", "status", "createdAt"]
    },
    "Lead": {
      "title": "Lead",
      "description": "A sales lead.",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "service": { "type": "string", "enum": ["WordPress", "Shopify", "Custom Development"] },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["New", "Contacted", "Converted"] },
        "assignedTo": { "type": "string", "description": "UID of the assigned user." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["companyId", "name", "status", "createdAt"]
    },
    "Invite": {
      "title": "Invite",
      "description": "An invitation for a new user to join a company.",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "manager", "team_lead", "sales"] },
        "token": { "type": "string" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "accepted"] }
      },
      "required": ["companyId", "email", "role", "token", "expiresAt", "status"]
    },
    "Task": {
      "title": "Task",
      "description": "A task associated with a lead or project.",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "dueDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Todo", "In Progress", "Review", "Done"] },
        "priority": { "type": "string", "enum": ["Low", "Medium", "High"] },
        "assignedTo": { "type": "string" },
        "leadId": { "type": "string" },
        "notificationSent": { "type": "boolean", "description": "Whether a due-soon notification has been sent." },
        "subtasks": { "type": "array", "items": { "type": "object" } },
        "attachments": { "type": "array", "items": { "type": "object" } },
        "reminderEnabled": { "type": "boolean" },
        "reminderMinutes": { "type": "number", "default": 30 },
        "reminderEmailSent": { "type": "boolean" },
        "startedAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["companyId", "title", "status", "createdAt"]
    },
    "TaskTemplate": {
      "title": "TaskTemplate",
      "description": "A template for creating tasks.",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "name": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "priority": { "type": "string" },
        "subtasks": { "type": "array", "items": { "type": "object" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["companyId", "name", "title", "createdAt"]
    },
    "ActivityLog": {
      "title": "ActivityLog",
      "description": "A log record for critical system operations.",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "actorId": { "type": "string" },
        "actorName": { "type": "string" },
        "action": { "type": "string", "enum": ["LOGIN", "SALARY_CHANGE", "EMPLOYEE_EDIT", "DATA_EXPORT", "SETTINGS_CHANGE", "TASK_EDIT", "LEAD_DELETE"] },
        "targetId": { "type": "string" },
        "targetName": { "type": "string" },
        "details": { "type": "string" },
        "metadata": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["companyId", "actorId", "actorName", "action", "details", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "Real-time in-app notifications for users.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "companyId": { "type": "string" },
        "type": { "type": "string", "enum": ["salary_update", "task_assigned", "profile_update", "admin_alert", "role_request", "new_message"] },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "link": { "type": "string" },
        "metadata": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "companyId", "type", "title", "message", "read", "createdAt"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A 1:1 or group chat conversation.",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "type": { "type": "string", "enum": ["direct", "group"] },
        "name": { "type": "string", "description": "Display name for group chats." },
        "photoURL": { "type": "string", "description": "Avatar for group chats." },
        "memberIds": { "type": "array", "items": { "type": "string" }, "description": "UIDs of participants." },
        "lastMessage": {
          "type": "object",
          "properties": {
            "content": { "type": "string" },
            "senderId": { "type": "string" },
            "senderName": { "type": "string" },
            "createdAt": { "type": "string", "format": "date-time" }
          }
        },
        "createdBy": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["companyId", "type", "memberIds", "updatedAt"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A single message in a conversation.",
      "type": "object",
      "properties": {
        "conversationId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "readBy": { "type": "array", "items": { "type": "string" } },
        "mentions": { "type": "array", "items": { "type": "string" } },
        "threadId": { "type": "string", "description": "For message threading/replies." }
      },
      "required": ["conversationId", "senderId", "senderName", "content", "createdAt"]
    },
    "UserPresence": {
      "title": "UserPresence",
      "description": "Real-time user status and typing indicators.",
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["online", "offline"] },
        "lastSeen": { "type": "string", "format": "date-time" },
        "typingIn": { "type": "string", "description": "ID of conversation user is typing in." }
      },
      "required": ["status", "lastSeen"]
    },
    "Form": {
      "title": "Form",
      "description": "A dynamic lead form structure.",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "type": { "type": "string", "enum": ["text", "textarea", "number", "email", "tel", "select"] },
              "required": { "type": "boolean" },
              "options": { "type": "array", "items": { "type": "string" } },
              "placeholder": { "type": "string" }
            }
          }
        },
        "isActive": { "type": "boolean" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["companyId", "name", "fields", "isActive", "createdAt"]
    },
    "FormSubmission": {
      "title": "FormSubmission",
      "description": "A submission for a specific dynamic form.",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "formId": { "type": "string" },
        "formName": { "type": "string" },
        "data": { "type": "object" },
        "submittedAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["New", "Read", "Converted"] }
      },
      "required": ["companyId", "formId", "data", "submittedAt"]
    },
    "Blog": {
      "title": "Blog",
      "description": "A blog instance within a company.",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "slug": { "type": "string" },
        "logoUrl": { "type": "string" },
        "footerText": { "type": "string" },
        "styling": {
          "type": "object",
          "properties": {
            "primaryColor": { "type": "string" },
            "backgroundColor": { "type": "string" },
            "cardColor": { "type": "string" },
            "textColor": { "type": "string" },
            "fontFamily": { "type": "string" },
            "layout": { "type": "string", "enum": ["grid", "list"] }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "categories": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["companyId", "name", "slug", "createdAt"]
    },
    "BlogPost": {
      "title": "BlogPost",
      "description": "A single post in a blog.",
      "type": "object",
      "properties": {
        "blogId": { "type": "string" },
        "companyId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string", "description": "Markdown content." },
        "excerpt": { "type": "string" },
        "slug": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "coverImage": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published"] },
        "tags": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string" },
        "publishedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["blogId", "companyId", "title", "content", "slug", "status", "createdAt"]
    },
    "BlogComment": {
      "title": "BlogComment",
      "description": "A comment on a blog post.",
      "type": "object",
      "properties": {
        "blogId": { "type": "string" },
        "postId": { "type": "string" },
        "companyId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorEmail": { "type": "string" },
        "content": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "spam"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["blogId", "postId", "companyId", "authorName", "content", "status", "createdAt"]
    },
    "MediaAsset": {
      "title": "MediaAsset",
      "description": "A stored media file for the company.",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "name": { "type": "string" },
        "url": { "type": "string" },
        "type": { "type": "string", "enum": ["image", "video", "document"] },
        "size": { "type": "number" },
        "dimensions": {
          "type": "object",
          "properties": {
            "width": { "type": "number" },
            "height": { "type": "number" }
          }
        },
        "tags": { "type": "array", "items": { "type": "string" } },
        "uploadedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["companyId", "name", "url", "type", "createdAt"]
    },
    "BlogAnalyticsEvent": {
      "title": "BlogAnalyticsEvent",
      "description": "Anonymized tracking event for blog analytics.",
      "type": "object",
      "properties": {
        "blogId": { "type": "string" },
        "postId": { "type": "string", "description": "Optional: set if the event is for a specific post." },
        "companyId": { "type": "string" },
        "eventType": { "type": "string", "enum": ["view", "engagement", "read_time"] },
        "source": { "type": "string", "description": "Traffic source (referrer)." },
        "value": { "type": "number", "description": "For read_time (seconds) or other metrics." },
        "userAgent": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["blogId", "companyId", "eventType", "createdAt"]
    },
    "AnalyticsEvent": {
      "title": "AnalyticsEvent",
      "description": "General purpose user interaction event.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "companyId": { "type": "string" },
