rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // 0. Global Safety Net & Helpers
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData(userId) {
      let path = /databases/$(database)/documents/users/$(userId);
      return exists(path) ? get(path).data : null;
    }

    function isCompanyMember(companyId) {
      // Pre-fetch user data once per evaluation
      let userData = getUserData(request.auth.uid);
      return isSignedIn() && 
             userData != null &&
             (userData.isSuperAdmin == true || userData.companyId == companyId);
    }

    function isMemberOfSameCompany(otherCompanyId) {
       let userData = getUserData(request.auth.uid);
       return isSignedIn() && userData != null && userData.companyId == otherCompanyId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function hasRole(roles) {
      let userData = getUserData(request.auth.uid);
      return isSignedIn() && 
             userData != null &&
             (userData.role in roles || userData.isSuperAdmin == true);
    }

    function isAdmin() {
      return hasRole(['admin']);
    }

    function isSuperAdmin() {
      let user = getUserData(request.auth.uid);
      return isSignedIn() && user != null && user.isSuperAdmin == true;
    }

    function isManager() {
      return hasRole(['manager', 'admin']);
    }
    
    function isOwnCompany(data) {
      let user = getUserData(request.auth.uid);
      return isSignedIn() && user != null && (user.isSuperAdmin == true || data.companyId == user.companyId);
    }

    // -------------------------------------------------------------------------
    // 1. Companies
    // -------------------------------------------------------------------------
    match /companies/{companyId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); // Allowed for subdomain uniqueness checks and finding company
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (isSuperAdmin() || (isAdmin() && isCompanyMember(companyId)));
    }

    // -------------------------------------------------------------------------
    // 2. Users (Personnel)
    // -------------------------------------------------------------------------
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin() || isMemberOfSameCompany(resource.data.companyId));
      allow list: if isSignedIn() && (isSuperAdmin() || isMemberOfSameCompany(resource.data.companyId));
      
      function isValidUser(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
               data.email is string && data.email.size() > 0 &&
               data.companyId is string &&
               data.role in ['admin', 'manager', 'team_lead', 'sales', 'super_admin'];
      }

      allow create: if isSignedIn() && (
        // Self-registration: Users can create their own profile once
        (request.auth.uid == userId) ||
        // Standard creation: Manager/Admin adding someone else
        (isManager() && isCompanyMember(incoming().companyId))
      ) && isValidUser(incoming());
      
      allow update: if isSignedIn() && (
        // Self-update: strictly prevent self-elevation to super admin
        (request.auth.uid == userId && (
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'photoURL', 'interests', 'pfp', 'memberId', 'notifications']) ||
          // Allow setting basic info on first setup, but NOT isSuperAdmin unless the requester IS already a super admin
          (existing().companyId == null && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email', 'companyId', 'role', 'memberId', 'uid', 'createdAt']))
        )) || 
        // Manager hierarchy control: Cannot elevate someone to super admin
        (isManager() && 
         isMemberOfSameCompany(existing().companyId) && 
         incoming().companyId == existing().companyId &&
         incoming().isSuperAdmin == existing().get('isSuperAdmin', false) &&
         (incoming().role == existing().role || isAdmin())) || 
        // Super Admin: Can do anything
        isSuperAdmin()
      );
    }

    // -------------------------------------------------------------------------
    // 3. CRM (Leads & Tasks)
    // -------------------------------------------------------------------------
    match /leads/{leadId} {
      allow get: if isSignedIn() && isOwnCompany(resource.data) && (isAdmin() || isManager() || resource.data.assignedTo == request.auth.uid);
      allow list: if isSignedIn() && isOwnCompany(resource.data) && (isAdmin() || isManager() || resource.data.assignedTo == request.auth.uid);
      allow write: if isSignedIn() && isOwnCompany(incoming()) && (isAdmin() || isManager() || hasRole(['sales']));
    }

    match /tasks/{taskId} {
      allow get: if isSignedIn() && isOwnCompany(resource.data) && (isAdmin() || isManager() || resource.data.assignedTo == request.auth.uid);
      allow list: if isSignedIn() && isOwnCompany(resource.data) && (isAdmin() || isManager() || resource.data.assignedTo == request.auth.uid);
      
      function isValidTask(data) {
        return data.companyId is string &&
               data.title is string && data.title.size() > 0 &&
               data.status in ['Todo', 'In Progress', 'Done', 'Review'] &&
               data.priority in ['Low', 'Medium', 'High'];
      }

      allow create: if isSignedIn() && isOwnCompany(incoming()) && (isAdmin() || isManager() || hasRole(['team_lead', 'sales', 'manager'])) && isValidTask(incoming());
      
      allow update: if isSignedIn() && (
        (isOwnCompany(existing()) && (isAdmin() || isManager() || hasRole(['team_lead', 'manager']))) ||
        (existing().assignedTo == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'subtasks', 'startedAt', 'completedAt']))
      ) && isValidTask(incoming());
      
      allow delete: if isSignedIn() && isOwnCompany(existing()) && (isAdmin() || isManager());
    }

    match /taskTemplates/{templateId} {
      allow get: if isCompanyMember(resource.data.companyId);
      allow list: if isCompanyMember(resource.data.companyId);
      allow write: if isCompanyMember(incoming().companyId) && isManager();
    }

    // -------------------------------------------------------------------------
    // 4. HR (Attendance, Leave, Shifts, etc.)
    // -------------------------------------------------------------------------
    match /attendance/{attendanceId} {
      allow get: if isCompanyMember(resource.data.companyId);
      allow list: if isCompanyMember(resource.data.companyId);
      allow create: if isCompanyMember(incoming().companyId) && request.auth.uid == incoming().employeeId;
      allow update: if isCompanyMember(incoming().companyId) && (request.auth.uid == existing().employeeId || isAdmin());
    }

    match /leaveRequests/{requestId} {
      allow get: if isCompanyMember(resource.data.companyId);
      allow list: if isCompanyMember(resource.data.companyId);
      allow create: if isCompanyMember(incoming().companyId) && request.auth.uid == incoming().employeeId;
      allow update: if isCompanyMember(incoming().companyId) && (isAdmin() || isManager());
    }

    match /shifts/{shiftId} {
      allow get: if isCompanyMember(resource.data.companyId);
      allow list: if isCompanyMember(resource.data.companyId);
      allow write: if isCompanyMember(incoming().companyId) && isManager();
    }

    match /holidays/{holidayId} {
      allow get: if isCompanyMember(resource.data.companyId);
      allow list: if isCompanyMember(resource.data.companyId);
      allow write: if isCompanyMember(incoming().companyId) && isManager();
    }

    match /employeeDocuments/{docId} {
      allow get: if isCompanyMember(resource.data.companyId) && (isManager() || request.auth.uid == resource.data.employeeId);
      allow list: if isCompanyMember(resource.data.companyId) && (isManager() || request.auth.uid == resource.data.employeeId);
      allow write: if isCompanyMember(incoming().companyId) && isAdmin();
    }

    match /exitRecords/{exitId} {
      allow get: if isCompanyMember(resource.data.companyId) && (isManager() || request.auth.uid == resource.data.employeeId);
      allow list: if isCompanyMember(resource.data.companyId) && (isManager() || request.auth.uid == resource.data.employeeId);
      allow write: if isCompanyMember(incoming().companyId) && isManager();
    }

    match /performanceReviews/{reviewId} {
      allow get: if isCompanyMember(resource.data.companyId) && (isManager() || request.auth.uid == resource.data.employeeId);
      allow list: if isCompanyMember(resource.data.companyId) && (isManager() || request.auth.uid == resource.data.employeeId);
      allow write: if isCompanyMember(incoming().companyId) && isManager();
    }

    match /payroll/{payrollId} {
      allow get: if isCompanyMember(resource.data.companyId) && (isManager() || request.auth.uid == resource.data.employeeId);
      allow list: if isCompanyMember(resource.data.companyId) && (isManager() || request.auth.uid == resource.data.employeeId);
      allow write: if isCompanyMember(incoming().companyId) && isManager();
    }

    match /intelligence/{postId} {
      allow get: if isSignedIn() && (resource.data.type == 'Global' || isCompanyMember(resource.data.companyId));
      allow list: if isSignedIn() && (
        (resource.data.type == 'Global') || 
        (resource.data.type == 'Internal' && isCompanyMember(resource.data.companyId))
      );
      allow create, update: if (incoming().type == 'Internal' && isManager() && isCompanyMember(incoming().companyId)) || (incoming().type == 'Global' && isAdmin());
      allow delete: if isAdmin();
    }

    match /permissionRequests/{requestId} {
      allow get: if isCompanyMember(resource.data.companyId);
      allow list: if isCompanyMember(resource.data.companyId);
      allow create: if isCompanyMember(incoming().companyId) && request.auth.uid == incoming().userId;
      allow update: if isCompanyMember(incoming().companyId) && (isAdmin() || isManager());
    }
    
    match /accessRequests/{requestId} {
      allow get: if isCompanyMember(resource.data.companyId);
      allow list: if isCompanyMember(resource.data.companyId);
      allow create: if isCompanyMember(incoming().companyId) && request.auth.uid == incoming().userId;
      allow update: if isCompanyMember(incoming().companyId) && (isAdmin() || isManager());
    }
    
    match /serviceRequests/{requestId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isManager());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || (isManager() && resource.data.companyId == getUserData(request.auth.uid).companyId));
      allow create: if isCompanyMember(incoming().companyId) && request.auth.uid == incoming().userId;
      allow update: if isCompanyMember(incoming().companyId) && (isManager() || (request.auth.uid == resource.data.userId && resource.data.status == 'PENDING'));
    }

    match /activityLogs/{logId} {
      function isValidActivityLog(data) {
        return data.companyId is string &&
               data.actorId == request.auth.uid &&
               data.actorName is string &&
               data.action in ["LOGIN", "SALARY_CHANGE", "EMPLOYEE_EDIT", "DATA_EXPORT", "SETTINGS_CHANGE", "TASK_EDIT", "LEAD_DELETE"] &&
               data.details is string &&
               data.createdAt is string;
      }
      allow create: if isSignedIn() && isCompanyMember(incoming().companyId) && isValidActivityLog(incoming());
      allow get: if isManager() && isCompanyMember(resource.data.companyId);
      allow list: if isManager() && isCompanyMember(resource.data.companyId);
    }
    
    match /invites/{inviteId} {
      allow read: if true;
      allow update: if isSignedIn() && (
        (resource.data.email == request.auth.token.email && incoming().diff(existing()).affectedKeys().hasOnly(['status']) && incoming().status == 'accepted') ||
        isManager()
      );
      allow create, delete: if isManager();
    }

    // -------------------------------------------------------------------------
    // 6. Chat (Conversations & Messages)
    // -------------------------------------------------------------------------
    function isConversationMember(memberIds) {
      return isSignedIn() && request.auth.uid in memberIds;
    }

    match /conversations/{conversationId} {
      allow get: if isConversationMember(resource.data.memberIds);
      allow list: if isSignedIn() && request.auth.uid in resource.data.memberIds;
      
      function isValidConversation(data) {
        return data.companyId is string &&
               data.type in ['direct', 'group'] &&
               data.memberIds is list &&
               data.memberIds.size() >= 2 &&
               data.memberIds.size() <= 50 &&
               (data.type == 'direct' ? data.memberIds.size() == 2 : true);
      }

      allow create: if isSignedIn() && 
                    isCompanyMember(incoming().companyId) && 
                    isValidConversation(incoming()) &&
                    request.auth.uid in incoming().memberIds;
      
      allow update: if isSignedIn() && 
                    isConversationMember(existing().memberIds) && (
                      // Update lastMessage and updatedAt during chat
                      incoming().diff(existing()).affectedKeys().hasOnly(['lastMessage', 'updatedAt']) ||
                      // Admins / Group Creators can manage group metadata
                      (existing().type == 'group' && (isAdmin() || request.auth.uid == existing().createdBy) && 
                       incoming().diff(existing()).affectedKeys().hasOnly(['name', 'photoURL', 'memberIds', 'updatedAt']))
                    );

      match /messages/{messageId} {
        function isValidChatMessage(data) {
          return data.conversationId == conversationId &&
                 data.senderId == request.auth.uid &&
                 data.content is string &&
                 data.content.size() > 0 &&
                 data.content.size() <= 2000;
        }

        allow read: if isSignedIn() && 
                    exists(/databases/$(database)/documents/conversations/$(conversationId)) &&
                    request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.memberIds;
        
        allow create: if isSignedIn() && 
                      isValidChatMessage(incoming()) &&
                      exists(/databases/$(database)/documents/conversations/$(conversationId)) &&
                      request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.memberIds;
        
        allow update: if isSignedIn() && 
                      request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.memberIds &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['readBy']);
      }
    }

    // -------------------------------------------------------------------------
    // 7. Presence & Contact Groups
    // -------------------------------------------------------------------------
    match /userPresence/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId || 
        (getUserData(request.auth.uid) != null && resource.data.companyId == getUserData(request.auth.uid).companyId)
      );
      
      allow write: if isSignedIn() && request.auth.uid == userId && 
                    (getUserData(request.auth.uid) != null && incoming().companyId == getUserData(request.auth.uid).companyId);
    }

    match /contactGroups/{groupId} {
      allow read, write: if isSignedIn() && (
        (isSuperAdmin() || (resource.data.companyId != null && isMemberOfSameCompany(resource.data.companyId))) ||
        (incoming().companyId != null && isMemberOfSameCompany(incoming().companyId))
      );
    }

    // -------------------------------------------------------------------------
    // 8. Support System
    // -------------------------------------------------------------------------
    match /supportTickets/{ticketId} {
      allow create: if true;
      allow read, update: if isSuperAdmin() || true; 
    }

    match /supportMessages/{messageId} {
      allow create: if true;
      allow read: if isSuperAdmin() || true;
    }

    // -------------------------------------------------------------------------
    // 5. Notifications
    // -------------------------------------------------------------------------
    match /notifications/{notificationId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isCompanyMember(incoming().companyId);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && (isAdmin() || incoming().diff(existing()).affectedKeys().hasOnly(['read']));
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // -------------------------------------------------------------------------
    // 8. Dynamic Forms
    // -------------------------------------------------------------------------
    match /forms/{formId} {
      function isValidForm(data) {
        return data.companyId is string &&
               data.name is string && data.name.size() > 0 &&
               data.fields is list && data.fields.size() > 0 &&
               data.isActive is bool;
      }
      // Forms are readable by anyone (for public submission) but listed only by members
      allow get: if true;
      allow list: if isSignedIn() && isCompanyMember(resource.data.companyId);
      allow create: if isManager() && isCompanyMember(incoming().companyId) && isValidForm(incoming());
      allow update: if isManager() && isCompanyMember(existing().companyId) && isValidForm(incoming());
      allow delete: if isAdmin() && isCompanyMember(resource.data.companyId);
    }

    match /formSubmissions/{submissionId} {
      function isValidSubmission(data) {
        return data.companyId is string &&
               data.formId is string &&
               data.data is map &&
               data.submittedAt is timestamp;
      }
      allow create: if isValidSubmission(incoming());
      allow read, update, delete: if isSignedIn() && isCompanyMember(resource.data.companyId) && isManager();
    }

    // -------------------------------------------------------------------------
    // 9. Blogs
    // -------------------------------------------------------------------------
    match /blogs/{blogId} {
      function isValidBlog(data) {
        return data.companyId is string &&
               data.name is string && data.name.size() > 0 &&
               data.slug is string && data.slug.matches('^[a-zA-Z0-9_\\-]+$');
      }
      allow read: if true; // Public access
      allow create: if isManager() && isCompanyMember(incoming().companyId) && isValidBlog(incoming());
      allow update: if isManager() && isCompanyMember(existing().companyId) && isValidBlog(incoming());
      allow delete: if isAdmin() && isCompanyMember(resource.data.companyId);
    }

    match /blogPosts/{postId} {
      function isValidBlogPost(data) {
        return data.companyId is string &&
               data.blogId is string &&
               data.title is string && data.title.size() > 0 &&
               data.content is string && data.content.size() > 0 &&
               data.slug is string && data.slug.matches('^[a-zA-Z0-9_\\-]+$') &&
               data.status in ['draft', 'published'];
      }
      allow read: if true; // Public access
      allow create: if isManager() && isCompanyMember(incoming().companyId) && isValidBlogPost(incoming());
      allow update: if isManager() && isCompanyMember(existing().companyId) && isValidBlogPost(incoming());
      allow delete: if isManager() && isCompanyMember(resource.data.companyId);
    }

    match /blogAnalyticsEvents/{eventId} {
      function isValidAnalyticsEvent(data) {
        return data.blogId is string &&
               data.companyId is string &&
               data.eventType in ['view', 'engagement', 'read_time'] &&
               data.createdAt == request.time;
      }
      allow create: if isValidAnalyticsEvent(incoming());
      allow read: if isSignedIn() && isCompanyMember(resource.data.companyId);
    }

    match /blogComments/{commentId} {
      function isValidComment(data) {
        return data.blogId is string &&
               data.postId is string &&
               data.companyId is string &&
               data.authorName is string && data.authorName.size() > 0 &&
               data.content is string && data.content.size() > 0 &&
               data.status in ['pending', 'approved', 'spam'];
      }
      allow read: if true;
      allow create: if isValidComment(incoming()) && incoming().status == 'pending';
      allow update, delete: if isManager() && isCompanyMember(resource.data.companyId);
    }

    match /mediaAssets/{assetId} {
      function isValidAsset(data) {
        return data.companyId is string &&
               data.name is string && data.name.size() > 0 &&
               data.url is string &&
               data.type in ['image', 'video', 'document'];
      }
      allow read: if isCompanyMember(resource.data.companyId) || isSuperAdmin();
      allow create: if isManager() && isCompanyMember(incoming().companyId) && isValidAsset(incoming());
      allow update: if isManager() && isCompanyMember(existing().companyId) && isValidAsset(incoming());
      allow delete: if isManager() && isCompanyMember(resource.data.companyId);
    }

    // 11. General Analytics
    match /analyticsEvents/{eventId} {
      function isValidAnalyticsEvent(data) {
        return data.userId is string && data.userId.size() <= 128 &&
               data.companyId is string && data.companyId.size() <= 128 &&
               data.eventName is string && data.eventName.size() <= 200 &&
               data.category in ['navigation', 'interaction', 'form', 'system'] &&
               data.metadata is map &&
               data.path is string && data.path.size() <= 512 &&
               data.timestamp == request.time;
      }
      allow create: if isValidAnalyticsEvent(incoming());
      allow read: if isSuperAdmin();
    }

    // 10. SaaS Nexvoura (Global)
    match /plans/{planId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /subscriptions/{subId} {
      allow read: if isSuperAdmin() || isCompanyMember(subId);
      allow write: if isSuperAdmin() || (isAdmin() && isCompanyMember(subId));
    }

    match /saas_payments/{paymentId} {
      allow read: if isSuperAdmin() || isCompanyMember(resource.data.companyId);
      allow write: if isSuperAdmin() || (isAdmin() && isCompanyMember(incoming().companyId));
    }

    match /discounts/{codeId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /system/{docId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }
  }
}
