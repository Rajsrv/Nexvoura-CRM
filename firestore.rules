rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // 0. Global Safety Net & Helpers
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function isCompanyMember(companyId) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             getUserData(request.auth.uid).companyId == companyId;
    }

    function hasRole(roles) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             getUserData(request.auth.uid).role in roles;
    }

    function isAdmin() {
      return hasRole(['admin']);
    }

    function isManager() {
      return hasRole(['manager', 'admin']);
    }

    // -------------------------------------------------------------------------
    // 1. Companies
    // -------------------------------------------------------------------------
    match /companies/{companyId} {
      allow read: if isSignedIn() && isCompanyMember(companyId);
      allow write: if isAdmin() && isCompanyMember(companyId);
    }

    // -------------------------------------------------------------------------
    // 2. Users (Personnel)
    // -------------------------------------------------------------------------
    match /users/{userId} {
      allow read: if (isSignedIn() && (resource.data.companyId == getUserData(request.auth.uid).companyId)) || (isSignedIn() && request.auth.uid == userId);
      
      function isValidUser(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
               data.email is string && data.email.size() > 0 &&
               data.companyId is string &&
               data.role in ['admin', 'manager', 'team_lead', 'sales'];
      }

      allow create: if isSignedIn() && isValidUser(incoming());
      
      allow update: if isSignedIn() && (
        // Self-update limited fields
        (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'photoURL'])) ||
        // Admin total control
        isAdmin() ||
        // Manager hierarchy control
        (isManager() && getUserData(userId).role in ['team_lead', 'sales'] && !incoming().diff(existing()).affectedKeys().hasAny(['role', 'companyId']))
      );
    }

    // -------------------------------------------------------------------------
    // 3. CRM (Leads & Tasks)
    // -------------------------------------------------------------------------
    match /leads/{leadId} {
      allow get: if isCompanyMember(resource.data.companyId) && (isAdmin() || isManager() || resource.data.assignedTo == request.auth.uid);
      allow list: if isCompanyMember(resource.data.companyId) && (isAdmin() || isManager() || resource.data.assignedTo == request.auth.uid);
      allow write: if isCompanyMember(incoming().companyId) && (isAdmin() || isManager() || hasRole(['sales']));
    }

    match /tasks/{taskId} {
      allow get: if isCompanyMember(resource.data.companyId) && (isAdmin() || isManager() || resource.data.assignedTo == request.auth.uid);
      allow list: if isCompanyMember(resource.data.companyId) && (isAdmin() || isManager() || resource.data.assignedTo == request.auth.uid);
      allow write: if isCompanyMember(incoming().companyId) && (isAdmin() || isManager() || hasRole(['team_lead', 'sales', 'manager']));
    }

    match /taskTemplates/{templateId} {
      allow get: if isCompanyMember(resource.data.companyId);
      allow list: if isCompanyMember(resource.data.companyId);
      allow write: if isCompanyMember(incoming().companyId) && isManager();
    }

    // -------------------------------------------------------------------------
    // 4. HR (Attendance, Leave, Shifts, etc.)
    // -------------------------------------------------------------------------
    match /attendance/{attendanceId} {
      allow get: if isCompanyMember(resource.data.companyId);
      allow list: if isCompanyMember(resource.data.companyId);
      allow create: if isCompanyMember(incoming().companyId) && request.auth.uid == incoming().employeeId;
      allow update: if isCompanyMember(incoming().companyId) && (request.auth.uid == existing().employeeId || isAdmin());
    }

    match /leaveRequests/{requestId} {
      allow get: if isCompanyMember(resource.data.companyId);
      allow list: if isCompanyMember(resource.data.companyId);
      allow create: if isCompanyMember(incoming().companyId) && request.auth.uid == incoming().employeeId;
      allow update: if isCompanyMember(incoming().companyId) && (isAdmin() || isManager());
    }

    match /shifts/{shiftId} {
      allow get: if isCompanyMember(resource.data.companyId);
      allow list: if isCompanyMember(resource.data.companyId);
      allow write: if isCompanyMember(incoming().companyId) && isManager();
    }

    match /holidays/{holidayId} {
      allow get: if isCompanyMember(resource.data.companyId);
      allow list: if isCompanyMember(resource.data.companyId);
      allow write: if isCompanyMember(incoming().companyId) && isManager();
    }

    match /employeeDocuments/{docId} {
      allow get: if isCompanyMember(resource.data.companyId) && (isManager() || request.auth.uid == resource.data.employeeId);
      allow list: if isCompanyMember(resource.data.companyId) && (isManager() || request.auth.uid == resource.data.employeeId);
      allow write: if isCompanyMember(incoming().companyId) && isAdmin();
    }

    match /exitRecords/{exitId} {
      allow get: if isCompanyMember(resource.data.companyId) && (isManager() || request.auth.uid == resource.data.employeeId);
      allow list: if isCompanyMember(resource.data.companyId) && (isManager() || request.auth.uid == resource.data.employeeId);
      allow write: if isCompanyMember(incoming().companyId) && isManager();
    }

    match /performanceReviews/{reviewId} {
      allow get: if isCompanyMember(resource.data.companyId) && (isManager() || request.auth.uid == resource.data.employeeId);
      allow list: if isCompanyMember(resource.data.companyId) && (isManager() || request.auth.uid == resource.data.employeeId);
      allow write: if isCompanyMember(incoming().companyId) && isManager();
    }

    match /payroll/{payrollId} {
      allow get: if isCompanyMember(resource.data.companyId) && (isManager() || request.auth.uid == resource.data.employeeId);
      allow list: if isCompanyMember(resource.data.companyId) && (isManager() || request.auth.uid == resource.data.employeeId);
      allow write: if isCompanyMember(incoming().companyId) && isManager();
    }

    match /permissionRequests/{requestId} {
      allow get: if isCompanyMember(resource.data.companyId);
      allow list: if isCompanyMember(resource.data.companyId);
      allow create: if isCompanyMember(incoming().companyId) && request.auth.uid == incoming().userId;
      allow update: if isCompanyMember(incoming().companyId) && (isAdmin() || isManager());
    }
    
    match /accessRequests/{requestId} {
      allow get: if isCompanyMember(resource.data.companyId);
      allow list: if isCompanyMember(resource.data.companyId);
      allow create: if isCompanyMember(incoming().companyId) && request.auth.uid == incoming().userId;
      allow update: if isCompanyMember(incoming().companyId) && (isAdmin() || isManager());
    }
    
    match /activityLogs/{logId} {
      function isValidActivityLog(data) {
        return data.companyId is string &&
               data.actorId == request.auth.uid &&
               data.actorName is string &&
               data.action in ["LOGIN", "SALARY_CHANGE", "EMPLOYEE_EDIT", "DATA_EXPORT", "SETTINGS_CHANGE", "TASK_EDIT", "LEAD_DELETE"] &&
               data.details is string &&
               data.createdAt is string;
      }
      allow create: if isSignedIn() && isCompanyMember(incoming().companyId) && isValidActivityLog(incoming());
      allow get: if isManager() && isCompanyMember(resource.data.companyId);
      allow list: if isManager() && isCompanyMember(resource.data.companyId);
    }
    
    match /invites/{inviteId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // 6. Chat (Conversations & Messages)
    // -------------------------------------------------------------------------
    function isConversationMember(memberIds) {
      return isSignedIn() && request.auth.uid in memberIds;
    }

    match /conversations/{conversationId} {
      allow get: if isConversationMember(resource.data.memberIds);
      allow list: if isSignedIn() && request.auth.uid in resource.data.memberIds;
      
      function isValidConversation(data) {
        return data.companyId is string &&
               data.type in ['direct', 'group'] &&
               data.memberIds is list &&
               data.memberIds.size() >= 2 &&
               data.memberIds.size() <= 50 &&
               (data.type == 'direct' ? data.memberIds.size() == 2 : true);
      }

      allow create: if isSignedIn() && 
                    isCompanyMember(incoming().companyId) && 
                    isValidConversation(incoming()) &&
                    request.auth.uid in incoming().memberIds;
      
      allow update: if isSignedIn() && 
                    isConversationMember(existing().memberIds) && (
                      // Update lastMessage and updatedAt during chat
                      incoming().diff(existing()).affectedKeys().hasOnly(['lastMessage', 'updatedAt']) ||
                      // Admins / Group Creators can manage group metadata
                      (existing().type == 'group' && (isAdmin() || request.auth.uid == existing().createdBy) && 
                       incoming().diff(existing()).affectedKeys().hasOnly(['name', 'photoURL', 'memberIds', 'updatedAt']))
                    );

      match /messages/{messageId} {
        function isValidChatMessage(data) {
          return data.conversationId == conversationId &&
                 data.senderId == request.auth.uid &&
                 data.content is string &&
                 data.content.size() > 0 &&
                 data.content.size() <= 2000;
        }

        allow read: if isSignedIn() && 
                    exists(/databases/$(database)/documents/conversations/$(conversationId)) &&
                    request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.memberIds;
        
        allow create: if isSignedIn() && 
                      isValidChatMessage(incoming()) &&
                      exists(/databases/$(database)/documents/conversations/$(conversationId)) &&
                      request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.memberIds;
        
        allow update: if isSignedIn() && 
                      request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.memberIds &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['readBy']);
      }
    }

    // -------------------------------------------------------------------------
    // 7. Presence
    // -------------------------------------------------------------------------
    match /userPresence/{userId} {
      allow read: if isSignedIn() && 
                   exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                   exists(/databases/$(database)/documents/users/$(userId)) &&
                   getUserData(request.auth.uid).companyId == getUserData(userId).companyId;
      
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // -------------------------------------------------------------------------
    // 5. Notifications
    // -------------------------------------------------------------------------
    match /notifications/{notificationId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isCompanyMember(incoming().companyId);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && (isAdmin() || incoming().diff(existing()).affectedKeys().hasOnly(['read']));
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
