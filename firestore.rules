rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isBootstrapAdmin() {
      return isAuthenticated() && 
             request.auth.token.email == "rajsaurav7585@gmail.com" && 
             request.auth.token.email_verified == true;
    }

    function getUserData() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : null;
    }

    function isSameCompany(companyId) {
      return isAuthenticated() && (
        isBootstrapAdmin() || 
        (getUserData() != null && getUserData().companyId == companyId)
      );
    }

    function hasRole(role) {
      return isAuthenticated() && (
        isBootstrapAdmin() || 
        (getUserData() != null && getUserData().role == role)
      );
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isManager() {
      return hasRole('manager');
    }

    function isSales() {
      return hasRole('sales');
    }

    function isTeamLead() {
      return hasRole('team_lead');
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Companies
    match /companies/{companyId} {
      allow read: if true; // Public access for join flow (limited by what the client knows)
      allow create: if isAuthenticated(); // Allow first user to create company
      allow update: if isSameCompany(companyId) && isAdmin();
    }

    // Users
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isSameCompany(resource.data.companyId));
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (request.auth.uid == userId || (isSameCompany(resource.data.companyId) && isAdmin()));
    }

    // Access Requests
    match /accessRequests/{requestId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && isAdmin();
      allow delete: if isAuthenticated() && isAdmin();
    }

    // Leads
    match /leads/{leadId} {
      allow read: if isAuthenticated() && isSameCompany(resource.data.companyId) && (
        isAdmin() || isManager() || isTeamLead() || (isSales() && resource.data.assignedTo == request.auth.uid)
      );
      allow create: if true; // Public lead submission allowed via API/Form
      allow update: if isAuthenticated() && isSameCompany(resource.data.companyId) && (
        isAdmin() || isManager() || isTeamLead() || (isSales() && resource.data.assignedTo == request.auth.uid)
      );
      allow delete: if isAuthenticated() && isSameCompany(resource.data.companyId) && isAdmin();
    }

    // Invites
    match /invites/{inviteId} {
      allow read: if true; // Needed for checking invite token
      allow create: if isAuthenticated() && isAdmin();
      allow update: if true; // Needed for accepting invite
      allow delete: if isAuthenticated() && isAdmin();
    }

    // Tasks
    match /tasks/{taskId} {
      allow read: if isAuthenticated() && isSameCompany(resource.data.companyId);
      allow create: if isAuthenticated() && isSameCompany(request.resource.data.companyId);
      allow update: if isAuthenticated() && isSameCompany(resource.data.companyId);
      allow delete: if isAuthenticated() && isSameCompany(resource.data.companyId) && (isAdmin() || isManager() || isTeamLead());
    }

    // Task Templates
    match /taskTemplates/{templateId} {
      allow read: if isAuthenticated() && isSameCompany(resource.data.companyId);
      allow create: if isAuthenticated() && isSameCompany(request.resource.data.companyId);
      allow update: if isAuthenticated() && isSameCompany(resource.data.companyId) && (isAdmin() || isManager() || isTeamLead());
      allow delete: if isAuthenticated() && isSameCompany(resource.data.companyId) && (isAdmin() || isManager() || isTeamLead());
    }

    // Payroll
    match /payroll/{payrollId} {
      allow read: if isAuthenticated() && isAdmin() && isSameCompany(resource.data.companyId);
      allow create: if isAuthenticated() && isAdmin() && isSameCompany(request.resource.data.companyId);
      allow update: if isAuthenticated() && isAdmin() && isSameCompany(resource.data.companyId);
      allow delete: if isAuthenticated() && isAdmin() && isSameCompany(resource.data.companyId);
    }
  }
}
