rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // 0. Global Safety Net & Helpers
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function getUserData(userId) { 
      let path = /databases/$(database)/documents/users/$(userId);
      return exists(path) ? get(path).data : {}; 
    }
    
    function isVerified() { return request.auth.token.email_verified == true; }
    
    // Core Identity Logic
    function isSelf(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    function getRole() { return getUserData(request.auth.uid).get('role', ''); }
    function isAdmin() { return isSignedIn() && getRole() == 'admin'; }
    function isManager() { return isSignedIn() && getRole() in ['manager', 'admin']; }
    function isTeamLead() { return isSignedIn() && getRole() in ['team_lead', 'manager', 'admin']; }
    function isManagement() { return isManager(); }
    
    function isCompanyMember(companyId) {
      return isSignedIn() && getUserData(request.auth.uid).get('companyId', '') == companyId;
    }

    // -------------------------------------------------------------------------
    // 2. Users (Personnel) - STRICT PII ISOLATION
    // -------------------------------------------------------------------------
    match /users/{userId} {
      // Users can read themselves, Team Leads can read peers, Managers read all in company
      allow read: if isSelf(userId) || (isTeamLead() && isCompanyMember(resource.data.companyId));
      
      function isValidUser(data) {
        return data.keys().hasAll(['name', 'email', 'companyId', 'role', 'createdAt']) && 
               data.name is string && data.name.size() < 100 &&
               data.email is string && data.email.size() < 100 &&
               data.role in ['admin', 'manager', 'team_lead', 'sales'] &&
               data.companyId is string &&
               (data.salary == null || data.salary is number);
      }

      allow create: if isSignedIn() && isValidUser(incoming());
      
      allow update: if (
        // Action: Profile Update (Self)
        (isSelf(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'photoURL'])) ||
        // Action: Admin Full Access
        isAdmin() ||
        // Action: Manager operational update
        (isManager() && isCompanyMember(existing().companyId) && 
         !incoming().diff(existing()).affectedKeys().hasAny(['role', 'companyId', 'email', 'salary']) &&
         existing().role != 'admin')
      ) && isValidUser(incoming());
    }

    // -------------------------------------------------------------------------
    // 3. Sensitive Employee Records
    // -------------------------------------------------------------------------
    
    // Payroll & Performance - ONLY Owner or Admin
    match /payroll/{payrollId} {
      allow read, list: if isSignedIn() && (request.auth.uid == resource.data.employeeId || isAdmin());
      allow write: if isAdmin();
    }

    match /performanceReviews/{reviewId} {
      allow read, list: if isSignedIn() && (request.auth.uid == resource.data.employeeId || isAdmin());
      allow write: if isAdmin();
    }

    match /employeeDocuments/{docId} {
      allow read, list: if isSignedIn() && (request.auth.uid == resource.data.employeeId || isAdmin());
      allow write: if isAdmin();
    }

    match /exitRecords/{exitId} {
      allow read, list: if isSignedIn() && (request.auth.uid == resource.data.employeeId || isAdmin());
      allow write: if isAdmin();
    }

    // Attendance & Leave - Owner or Team Lead+
    match /attendance/{attendanceId} {
      allow read, list: if isSignedIn() && (request.auth.uid == resource.data.employeeId || (isTeamLead() && isCompanyMember(resource.data.companyId)));
      allow create: if isSignedIn() && incoming().employeeId == request.auth.uid;
      allow update: if isSignedIn() && (
        (isSelf(existing().employeeId) && incoming().diff(existing()).affectedKeys().hasOnly(['checkOut'])) ||
        isManagement()
      );
    }

    match /leaveRequests/{requestId} {
      allow read, list: if isSignedIn() && (request.auth.uid == resource.data.employeeId || (isTeamLead() && isCompanyMember(resource.data.companyId)));
      allow create: if isSignedIn() && incoming().employeeId == request.auth.uid && incoming().status == 'Pending';
      allow update: if isManagement() || (isSelf(existing().employeeId) && existing().status == 'Pending' && !incoming().diff(existing()).affectedKeys().hasAny(['status']));
      allow delete: if isManagement() || (isSelf(existing().employeeId) && existing().status == 'Pending');
    }

    match /permissionRequests/{requestId} {
      allow get: if isCompanyMember(resource.data.companyId);
      allow list: if isCompanyMember(resource.data.companyId);
      allow create: if isCompanyMember(incoming().companyId) && request.auth.uid == incoming().userId;
      allow update: if isCompanyMember(incoming().companyId) && (isAdmin() || isManager());
    }
    
    match /invites/{inviteId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /accessRequests/{requestId} {
      allow read: if isManagement() && isCompanyMember(resource.data.companyId);
      allow list: if isManagement() && isCompanyMember(resource.data.companyId);
      allow create: if isCompanyMember(incoming().companyId);
      allow update: if isManagement();
    }

    match /shifts/{shiftId} {
      allow read, list: if isSignedIn() && isCompanyMember(resource.data.companyId);
      allow write: if isManagement();
    }

    match /holidays/{holidayId} {
      allow read, list: if isSignedIn() && isCompanyMember(resource.data.companyId);
      allow write: if isManagement();
    }

    match /taskTemplates/{templateId} {
      allow read, list: if isSignedIn() && isCompanyMember(resource.data.companyId);
      allow write: if isManagement();
    }

    // -------------------------------------------------------------------------
    // 4. CRM Core (Leads, Tasks, Companies)
    // -------------------------------------------------------------------------

    match /companies/{companyId} {
      allow read: if isCompanyMember(companyId);
      allow write: if isAdmin() && isCompanyMember(companyId);
    }

    match /leads/{leadId} {
      allow read: if isSignedIn() && isCompanyMember(resource.data.companyId);
      allow list: if isSignedIn() && isCompanyMember(resource.data.companyId);
      allow create: if isSignedIn() && isCompanyMember(incoming().companyId);
      allow update: if isSignedIn() && isCompanyMember(resource.data.companyId);
      allow delete: if isManagement();
    }

    match /tasks/{taskId} {
      allow read: if isSignedIn() && isCompanyMember(resource.data.companyId);
      allow list: if isSignedIn() && isCompanyMember(resource.data.companyId);
      allow create: if isSignedIn() && isCompanyMember(incoming().companyId);
      allow update: if isSignedIn() && isCompanyMember(resource.data.companyId);
      allow delete: if isManagement();
    }
  }
}
